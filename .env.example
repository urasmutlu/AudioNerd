# Copy this file to `.env` and fill in your real credentials.
# `.env` is gitignored — never commit your real keys.

# From https://developer.spotify.com/dashboard (your app's settings)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Must EXACTLY match a Redirect URI registered in your Spotify app settings.
# Spotify requires 127.0.0.1 (not localhost) for loopback redirects.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# From https://getsongbpm.com/api
GETSONGBPM_API_KEY=your_getsongbpm_api_key
